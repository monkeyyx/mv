{
  "openapi": "3.1.0",
  "info": {
    "title": "MyFlixi | Ultra-Media API",
    "version": "2.1.0",
    "description": "High-performance modular API for Showbox media discovery and FebBox cloud orchestration."
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Development Server" }
  ],
  "tags": [
    { "name": "Media Discovery", "description": "Showbox Search & Metadata" },
    {
      "name": "Discover",
      "description": "Discover Movies & TV Shows via TMDB"
    },
    { "name": "FebBox Cloud", "description": "Cloud Storage & Streaming" },
    { "name": "System", "description": "Health & Configuration" }
  ],
  "paths": {
    "/api/system/status": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "responses": { "200": { "description": "Online" } }
      }
    },
    "/api/system/set-cookie": {
      "get": {
        "tags": ["System"],
        "summary": "Set Auth Cookie",
        "parameters": [
          {
            "name": "secret",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "admin"
          },
          {
            "name": "cookie",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "your_cookie_here"
          }
        ],
        "responses": { "200": { "description": "Cookie updated" } }
      }
    },
    "/api/media/autocomplete": {
      "get": {
        "tags": ["Media Discovery"],
        "summary": "Autocomplete Suggestions",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "schema": { "type": "string" },
            "example": "Avatar"
          }
        ],
        "responses": { "200": { "description": "Suggestions list" } }
      }
    },
    "/api/media/search": {
      "get": {
        "tags": ["Media Discovery"],
        "summary": "Global Search",
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "schema": { "type": "string" },
            "example": "Avatar"
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "example": "movie"
          }
        ],
        "responses": { "200": { "description": "Media results" } }
      }
    },
    "/api/media/movie/{id}": {
      "get": {
        "tags": ["Media Discovery"],
        "summary": "Movie Details (with HLS Hunting)",
        "description": "Fetches metadata and automatically hunts for a playable HLS stream in the background.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": false,
            "schema": { "type": "string" },
            "example": "24535"
          }
        ],
        "responses": { 
          "200": { 
            "description": "Metadata with stream sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "isAvailable": { "type": "boolean" },
                    "stream_sources": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "quality": { "type": "string" },
                          "is_hls": { "type": "boolean" },
                          "stream_url": { "type": "string" }
                        }
                      }
                    },
                    "real_stream_link": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          } 
        }
      }
    },
    "/api/media/show/{id}": {
      "get": {
        "tags": ["Media Discovery"],
        "summary": "TV Show Details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": false,
            "schema": { "type": "string" },
            "example": "125"
          }
        ],
        "responses": { "200": { "description": "Metadata with episodes" } }
      }
    },
    "/api/media/movies/featured": {
      "get": {
        "tags": ["Media Discovery"],
        "summary": "Featured Movies",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "example": 1
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer" },
            "example": 20
          }
        ],
        "responses": { "200": { "description": "List of featured movies" } }
      }
    },
    "/api/discover/movies/popular": {
      "get": {
        "tags": ["Discover"],
        "summary": "Popular Movies (from TMDB)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "example": 1
          },
          {
            "name": "check",
            "in": "query",
            "description": "Perform deep HLS availability check (Slower)",
            "schema": { "type": "boolean" },
            "example": true
          }
        ],
        "responses": { "200": { "description": "List of popular movies" } }
      }
    },
    "/api/febbox/watch/{fid}": {
      "get": {
        "tags": ["FebBox Cloud"],
        "summary": "Resolve Stream Links",
        "parameters": [
          {
            "name": "fid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "46901362"
          }
        ],
        "responses": { 
          "200": { 
            "description": "Episode stream sources with HLS Hunting",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fid": { "type": "string" },
                    "isAvailable": { "type": "boolean" },
                    "stream_sources": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "quality": { "type": "string" },
                          "is_hls": { "type": "boolean" },
                          "stream_url": { "type": "string" }
                        }
                      }
                    },
                    "real_stream_link": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          } 
        }
      }
    },
    "/api/febbox/stream/{fid}": {
      "get": {
        "tags": ["FebBox Cloud"],
        "summary": "Proxy Video Stream",
        "parameters": [
          {
            "name": "fid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "46901362"
          },
          {
            "name": "quality",
            "in": "query",
            "schema": { "type": "string" },
            "example": "ORG"
          }
        ],
        "responses": { "200": { "description": "Video stream" } }
      }
    }
  }
}
